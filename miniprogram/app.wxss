page {
  min-height: 100%;
  background: #fff7f3;
  color: #4d3941;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 10% 6%, rgba(255, 194, 210, 0.56), transparent 26%),
    radial-gradient(circle at 90% 0%, rgba(247, 200, 94, 0.24), transparent 20%),
    #fff7f3;
}

.soft-panel {
  border: 2rpx solid rgba(255, 216, 224, 0.8);
  border-radius: 36rpx;
  background: rgba(255, 252, 250, 0.92);
  box-shadow: 0 18rpx 50rpx rgba(165, 113, 127, 0.12);
}

.nav-row,
.between-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #473039;
  font-size: 30rpx;
  font-weight: 700;
}

.muted {
  color: #9a8188;
}

.primary-button {
  min-height: 92rpx;
  border: 0;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ff7897, #ff6588);
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 34rpx rgba(255, 111, 145, 0.28);
}

.ghost-button {
  border: 2rpx solid #ffd4df;
  border-radius: 36rpx;
  background: #fffaf7;
  color: #7b5663;
}

.star-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background: #f7c85e;
  box-shadow: 0 0 0 6rpx rgba(247, 200, 94, 0.18);
  transform: rotate(45deg);
}

.excel-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 46rpx;
  height: 46rpx;
  border-radius: 14rpx;
  background: #62b98c;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 700;
}

.back-link {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #473039;
  font-size: 40rpx;
  line-height: 52rpx;
  text-align: center;
}

.score-stars {
  color: #f5a623;
  font-size: 28rpx;
  letter-spacing: 0;
}
