.analyze-page {
  padding-top: 20rpx;
}

.page-title {
  font-size: 30rpx;
  font-weight: 700;
}

.research-copy {
  margin: 42rpx 0 16rpx;
  text-align: center;
}

.headline {
  margin: 20rpx auto 0;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.3;
}

.research-file {
  margin-top: 14rpx;
}

.analysis-detail {
  margin-top: 10rpx;
  color: #6b7d74;
  font-size: 24rpx;
  line-height: 1.65;
}

.analysis-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 22rpx;
}

.analysis-badge {
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #7d8478;
  font-size: 20rpx;
  line-height: 42rpx;
}

.analysis-badge.is-active {
  background: #25443d;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(37, 68, 61, 0.18);
}

.study-stage {
  position: relative;
  height: 438rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border: 3rpx solid rgba(219, 198, 152, 0.9);
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 18% 18%, rgba(244, 140, 128, 0.18), transparent 24%),
    radial-gradient(circle at 82% 20%, rgba(66, 184, 180, 0.18), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 240, 0.92), rgba(255, 245, 219, 0.94));
}

.stage-glow {
  position: absolute;
  border-radius: 50%;
  animation: glow-shift 3s ease-in-out infinite;
}

.glow-a {
  top: 24rpx;
  left: 34rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(244, 140, 128, 0.2);
}

.glow-b {
  right: 30rpx;
  bottom: 28rpx;
  width: 136rpx;
  height: 136rpx;
  background: rgba(66, 184, 180, 0.18);
}

.scan-ring {
  position: absolute;
  border: 3rpx solid rgba(66, 184, 180, 0.2);
  border-radius: 50%;
  animation: pulse-soft 2.8s ease-in-out infinite;
}

.ring-a {
  top: 92rpx;
  left: 228rpx;
  width: 198rpx;
  height: 198rpx;
}

.ring-b {
  top: 116rpx;
  left: 204rpx;
  width: 246rpx;
  height: 246rpx;
  animation-delay: 0.3s;
}

.desk {
  position: absolute;
  right: 94rpx;
  bottom: 54rpx;
  left: 94rpx;
  height: 58rpx;
  border: 2rpx solid #dfa788;
  border-radius: 18rpx 18rpx 0 0;
  background: linear-gradient(90deg, #f4c95d, #dfeacb);
}

.mascot {
  position: absolute;
  right: 222rpx;
  bottom: 88rpx;
  width: 210rpx;
  height: 236rpx;
  border-radius: 110rpx 110rpx 80rpx 80rpx;
  background: #f7c85e;
  box-shadow: 0 18rpx 36rpx rgba(147, 111, 43, 0.16);
  animation: float-slow 3.2s ease-in-out infinite;
}

.mascot-face {
  position: absolute;
  top: 68rpx;
  left: 38rpx;
  width: 142rpx;
  height: 138rpx;
  border-radius: 50%;
  background: #ffd7c7;
}

.hood-star {
  position: absolute;
  top: -18rpx;
  left: 90rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: #f7c85e;
  border: 2rpx solid #ce8e18;
  transform: rotate(45deg);
}

.glass {
  position: absolute;
  top: 102rpx;
  right: -10rpx;
  width: 74rpx;
  height: 74rpx;
  border: 10rpx solid #4d5b63;
  border-radius: 50%;
}

.float-file {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 130rpx;
  border: 2rpx solid #efd6cf;
  border-radius: 18rpx;
  background: #fffdf3;
  color: #62b98c;
  font-size: 42rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 30rpx rgba(126, 93, 104, 0.12);
}

.file-a {
  top: 120rpx;
  left: 30rpx;
  transform: rotate(-18deg);
  animation: float-slow 2.8s ease-in-out infinite;
}

.file-b {
  top: 74rpx;
  right: 42rpx;
  transform: rotate(14deg);
  animation: float-slow 3.1s ease-in-out infinite;
  animation-delay: 0.2s;
}

.file-c {
  top: 244rpx;
  right: 70rpx;
  color: #7d9f7f;
  transform: rotate(-8deg);
  animation: float-slow 2.9s ease-in-out infinite;
  animation-delay: 0.4s;
}

.stage-note {
  position: absolute;
  z-index: 2;
  max-width: 190rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 16rpx 32rpx rgba(126, 93, 104, 0.1);
}

.stage-note-left {
  top: 34rpx;
  left: 26rpx;
}

.stage-note-right {
  right: 22rpx;
  bottom: 34rpx;
}

.stage-note-label {
  color: #8a8d78;
  font-size: 18rpx;
}

.stage-note-value {
  margin-top: 8rpx;
  color: #25443d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
}

.progress-card {
  margin-top: 22rpx;
  padding: 30rpx;
}

.progress-status {
  min-width: 132rpx;
}

.progress-number {
  margin-top: 22rpx;
  color: #25443d;
  font-size: 56rpx;
  font-weight: 800;
}

.track {
  height: 16rpx;
  margin: 18rpx 0 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f7e4e7;
}

.fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f4c95d, #42b8b4);
  box-shadow: 0 10rpx 20rpx rgba(66, 184, 180, 0.18);
  transition: width 0.35s ease;
}

.progress-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.summary-pill {
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff7d8;
  color: #726e5e;
  font-size: 18rpx;
  line-height: 40rpx;
}

.step-row {
  display: flex;
  align-items: center;
  min-height: 64rpx;
  color: #6d5861;
  border-bottom: 2rpx solid #f7eceb;
}

.step-row:last-child {
  border-bottom: 0;
}

.done-row {
  color: #567a6a;
}

.step-check {
  width: 30rpx;
  height: 30rpx;
  margin-right: 16rpx;
  border: 2rpx solid #dab9c1;
  border-radius: 8rpx;
  color: #c9a0ac;
  line-height: 28rpx;
  text-align: center;
}

.step-check.done,
.step-state {
  color: #3ca16d;
}

.step-label {
  flex: 1;
}

.sheet-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.sheet-intro {
  margin: 16rpx 0 12rpx;
  color: #74857a;
  font-size: 22rpx;
  line-height: 1.6;
}

.sheet-row {
  display: flex;
  align-items: center;
  min-height: 86rpx;
  border-bottom: 2rpx solid #f7eceb;
}

.sheet-row:last-child {
  border-bottom: 0;
}

.sheet-copy {
  margin-left: 16rpx;
  font-size: 25rpx;
}

.sheet-name {
  color: #25443d;
  font-weight: 700;
}

.sheet-copy .muted {
  margin-top: 5rpx;
  font-size: 21rpx;
}

.sheet-preview {
  max-height: 220rpx;
  margin: 0 0 18rpx 54rpx;
  overflow: hidden;
  border: 2rpx solid #f1dedb;
  border-radius: 18rpx;
  background: #fff8e8;
}

.preview-row {
  display: flex;
}

.preview-cell {
  flex: 1;
  min-width: 88rpx;
  max-width: 148rpx;
  overflow: hidden;
  padding: 8rpx;
  border-right: 2rpx solid #f4e8e5;
  border-bottom: 2rpx solid #f4e8e5;
  color: #765863;
  font-size: 18rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tip {
  margin: 28rpx 0 18rpx;
  color: #738277;
  font-size: 23rpx;
  line-height: 1.6;
  text-align: center;
}

.report-button {
  margin-top: 6rpx;
}
