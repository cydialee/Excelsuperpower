<view class="page-shell plans-page">
  <view class="filter-row">
    <view wx:for="{{filters}}" wx:key="*this" class="filter {{index === 0 ? 'active' : ''}}">{{item}}</view>
  </view>

  <swiper class="plan-swiper" current="{{activeIndex}}" autoplay circular interval="3600" duration="520" previous-margin="28rpx" next-margin="28rpx" bindchange="changePlan">
    <swiper-item wx:for="{{plans}}" wx:key="id">
      <view class="soft-panel plan-card {{selectedId === item.id ? 'selected' : ''}}" data-id="{{item.id}}" bindtap="selectPlan">
        <view class="between-row">
          <view class="plan-title">{{item.name}} · {{item.title}} <text wx:if="{{index === 0 || item.recommended}}">(推荐)</text></view>
          <view wx:if="{{selectedId === item.id}}" class="pick">✓</view>
        </view>
        <view class="plan-body">
          <view class="plan-metrics">
            <view wx:if="{{item.pages}}">分页结果　<text>{{item.pages}}</text></view>
            <view wx:if="{{item.paperUse}}">纸张利用率　<text>{{item.paperUse}}</text></view>
            <view wx:if="{{item.description}}">{{item.description}}</view>
            <view wx:if="{{item.fitToWidth}}">宽度适配　<text>{{item.fitToWidth}} 页</text></view>
            <view>推荐指数　<text class="score-stars">{{item.score >= 5 ? '★★★★★' : '★★★★☆'}}</text></view>
          </view>
          <view class="paper-preview">
            <view></view><view></view>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="action-row">
    <button class="primary-button grow" bindtap="comparePlan">查看分页预览</button>
    <button class="ghost-button tune" bindtap="tuneSettings">设置</button>
  </view>
</view>
