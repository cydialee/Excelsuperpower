.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: 28rpx 4rpx 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #102a43;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #52616b;
}

.panel {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 42, 67, 0.08);
}

.section-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #17202a;
}

.upload-button,
.generate-button {
  background: #176b87;
  color: #ffffff;
  border-radius: 8rpx;
}

.file-name {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #52616b;
  word-break: break-all;
}

.sheet-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f5;
}

.sheet-row:last-child {
  border-bottom: 0;
}

.sheet-info {
  margin-left: 18rpx;
}

.sheet-name {
  font-size: 28rpx;
  font-weight: 600;
}

.sheet-meta,
.plan-desc,
.diagnosis {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #697985;
}

.plan {
  padding: 22rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid #d9e4ea;
  border-radius: 8rpx;
}

.plan-active {
  border-color: #176b87;
  background: #eef8fb;
}

.plan-name {
  font-size: 28rpx;
  font-weight: 700;
}

.download-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  font-size: 26rpx;
}
