<view class="page-shell workbench">
  <view class="brand-row">
    <view class="brand-mark">P</view>
    <view>
      <view class="brand-name">PrintMind</view>
      <view class="brand-caption">AI 打印助手</view>
    </view>
    <view class="header-stars">
      <view class="star-dot"></view>
      <view class="bell">⌁</view>
    </view>
  </view>

  <view class="hero-copy">
    <view class="hero-title">PrintMind</view>
    <view class="hero-subtitle">AI 打印助手</view>
  </view>

  <view class="file-stage">
    <view class="paper paper-left"></view>
    <view class="paper paper-center"></view>
    <view class="paper paper-right"></view>
    <swiper
      class="promo-swiper"
      autoplay
      circular
      interval="2600"
      duration="520"
      indicator-dots
      indicator-color="rgba(255,255,255,.54)"
      indicator-active-color="#ffffff"
      bindtap="previewFlow"
    >
      <swiper-item wx:for="{{promoSlides}}" wx:key="id">
        <view class="play-panel promo-{{item.tone}}">
          <view class="panel-copy">{{item.title}}</view>
          <view class="panel-subtitle">{{item.subtitle}}</view>
          <view class="play-arrow"></view>
          <view class="tiny-helper">
            <view class="helper-face"></view>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="upload-card soft-panel" bindtap="chooseExcelFile">
    <view class="section-title">拖拽 Excel 文件到这里</view>
    <view class="muted">或点击上传文件</view>
    <view class="support-line">支持 .xlsx / .xlsm 格式</view>
  </view>

  <view class="between-row list-heading">
    <view class="section-title">最近文件</view>
    <view class="all-link" bindtap="openBatch">全部 ›</view>
  </view>
  <view class="soft-panel recent-list">
    <view wx:for="{{recentFiles}}" wx:key="id" class="recent-row" bindtap="openRecent">
      <view class="excel-pill">X</view>
      <view class="recent-name">{{item.name}}</view>
      <view class="recent-time">{{item.updatedAt}}</view>
    </view>
  </view>
</view>
