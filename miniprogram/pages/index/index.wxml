<view class="page-shell workbench {{pageReady ? 'page-entered' : ''}}">
  <view class="hero-panel soft-panel">
    <view class="brand-row reveal-block">
      <view class="brand-mark">印</view>
      <view class="brand-copy">
        <view class="brand-name">Excel 打印工作台</view>
        <view class="brand-caption">导入识别 · 区域确认 · 分页对比 · 导出结果</view>
      </view>
      <view class="header-stars">
        <view class="glass-tag header-tag">AI 就绪</view>
        <view class="star-dot"></view>
        <view class="bell">•</view>
      </view>
    </view>

    <view class="hero-copy reveal-block delay-1">
      <view class="section-kicker">Excel Print Studio</view>
      <view class="hero-title">让打印结果像正式交付，而不只是“能打出来”</view>
      <view class="hero-subtitle">从 Sheet、打印区域到分页方式，整条链路都按更接近 Excel 的逻辑来处理。</view>
      <view class="hero-dynamic-line">
        <text class="hero-dynamic-word">{{headlineWords[activeHeroWordIndex]}}</text>
        <text class="hero-dynamic-copy">{{heroStatusLine}}</text>
      </view>
    </view>

    <view class="flow-strip reveal-block delay-2">
      <view
        wx:for="{{flowSteps}}"
        wx:key="id"
        class="flow-item {{activeFlowIndex === index ? 'active' : ''}}"
      >
        <view class="flow-topline">
          <text class="flow-index">{{item.index}}</text>
          <text class="flow-label">{{item.label}}</text>
        </view>
        <view class="flow-detail">{{item.detail}}</view>
      </view>
    </view>

    <view class="file-stage reveal-block delay-3">
      <view class="ambient-orb orb-left"></view>
      <view class="ambient-orb orb-right"></view>
      <view class="paper paper-left"></view>
      <view class="paper paper-center"></view>
      <view class="paper paper-right"></view>
      <view class="hero-floating-card floating-top">
        <view class="floating-label">当前亮点</view>
        <view class="floating-value">保留 Excel 原打印区域优先级</view>
      </view>
      <view class="hero-floating-card floating-bottom">
        <view class="floating-label">输出结果</view>
        <view class="floating-value">优化 Excel / 打印 PDF / 批量任务</view>
      </view>
      <swiper
        class="promo-swiper"
        autoplay
        circular
        interval="2600"
        duration="520"
        indicator-dots
        indicator-color="rgba(255,255,255,.54)"
        indicator-active-color="#ffffff"
        bindtap="previewFlow"
        bindchange="handlePromoChange"
      >
        <swiper-item wx:for="{{promoSlides}}" wx:key="id">
          <view class="play-panel promo-{{item.tone}}">
            <view class="panel-copy">{{item.title}}</view>
            <view class="panel-subtitle">{{item.subtitle}}</view>
            <view class="play-arrow"></view>
            <view class="tiny-helper">
              <view class="helper-face"></view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="hero-metrics reveal-block delay-4">
      <view
        wx:for="{{heroMetrics}}"
        wx:key="label"
        class="metric-chip metric-{{item.tone}}"
      >
        <view class="metric-value">{{item.value}}</view>
        <view class="metric-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="upload-card soft-panel reveal-block delay-3" bindtap="chooseExcelFile">
    <view class="upload-glow"></view>
    <view class="section-kicker">上传入口</view>
    <view class="section-title">导入 Excel 表格</view>
    <view class="muted">支持读取真实 Sheet、现有打印区域、表头结构和分页建议。</view>
    <view class="support-line">支持 `.xlsx` / `.xlsm` 文件，点击即可开始识别</view>
    <view class="upload-pill-row">
      <view class="glass-tag upload-pill">识别真实 Sheet</view>
      <view class="glass-tag upload-pill">沿用 Excel 打印区</view>
      <view class="glass-tag upload-pill">进入分析工作流</view>
    </view>
  </view>

  <view class="capability-rack reveal-block delay-4">
    <view
      wx:for="{{featureCards}}"
      wx:key="id"
      class="feature-card soft-panel"
    >
      <view class="feature-eyebrow">{{item.eyebrow}}</view>
      <view class="feature-title">{{item.title}}</view>
      <view class="feature-detail">{{item.detail}}</view>
      <view class="feature-meter">
        <view class="feature-meter-fill"></view>
        <view class="feature-meter-tag">{{item.stat}}</view>
      </view>
    </view>
  </view>

  <view class="between-row list-heading reveal-block delay-5">
    <view class="section-title">最近任务</view>
    <view class="all-link" bindtap="openBatch">批量任务 →</view>
  </view>
  <view class="soft-panel recent-list reveal-block delay-5">
    <view wx:for="{{recentFiles}}" wx:key="id" class="recent-row" bindtap="openRecent">
      <view class="excel-pill">X</view>
      <view class="recent-main">
        <view class="recent-name">{{item.name}}</view>
        <view class="recent-status status-{{item.tone}}">{{item.status}}</view>
      </view>
      <view class="recent-time">{{item.updatedAt}}</view>
    </view>
  </view>
</view>
