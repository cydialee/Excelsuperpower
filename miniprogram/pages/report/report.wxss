.page-title {
  font-size: 31rpx;
  font-weight: 700;
}

.report-intro {
  margin-top: 36rpx;
  text-align: center;
}

.report-title {
  margin-top: 18rpx;
  font-size: 43rpx;
  font-weight: 800;
  line-height: 1.35;
}

.report-subtitle {
  margin-top: 12rpx;
  color: #8f717b;
  text-align: center;
}

.report-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.report-tag {
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  color: #677d74;
  font-size: 18rpx;
  line-height: 42rpx;
}

.map-stage {
  position: relative;
  height: 520rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 44rpx;
  background:
    radial-gradient(circle at 18% 34%, #8bc79f 0 54rpx, transparent 56rpx),
    radial-gradient(circle at 82% 28%, #f08e7f 0 48rpx, transparent 50rpx),
    linear-gradient(180deg, #dff0d1, #a8d38e);
}

.map-glow {
  position: absolute;
  border-radius: 50%;
  animation: glow-shift 3s ease-in-out infinite;
}

.map-glow-left {
  top: 40rpx;
  left: 52rpx;
  width: 110rpx;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.2);
}

.map-glow-right {
  top: 60rpx;
  right: 66rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.14);
}

.hill {
  position: absolute;
  right: -40rpx;
  bottom: -72rpx;
  left: -40rpx;
  height: 270rpx;
  border-radius: 50%;
  background: #d7d88e;
}

.fountain {
  position: absolute;
  top: 154rpx;
  left: 266rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #7bc7d6;
  box-shadow: inset 0 -18rpx 0 #e9c26e;
  animation: pulse-soft 2.8s ease-in-out infinite;
}

.fountain view {
  width: 42rpx;
  height: 42rpx;
  margin: 40rpx auto;
  border-radius: 12rpx;
  background: #f7c85e;
  transform: rotate(45deg);
}

.map-helper {
  position: absolute;
  bottom: 82rpx;
  width: 100rpx;
  height: 126rpx;
  border-radius: 56rpx 56rpx 38rpx 38rpx;
  background: #f7c85e;
  animation: float-slow 3s ease-in-out infinite;
}

.map-helper.left {
  left: 110rpx;
}

.map-helper.right {
  right: 144rpx;
  background: #ffb17f;
}

.risk-bubble {
  position: absolute;
  max-width: 176rpx;
  padding: 18rpx;
  border: 2rpx solid #e8d0ca;
  border-radius: 22rpx;
  background: rgba(255, 252, 250, 0.95);
  box-shadow: 0 16rpx 30rpx rgba(90, 75, 67, 0.1);
  font-size: 22rpx;
  animation: float-slow 3.2s ease-in-out infinite;
}

.risk-count {
  color: #25837f;
  font-weight: 700;
}

.bubble-0 {
  top: 30rpx;
  left: 28rpx;
  animation-delay: 0.1s;
}

.bubble-1 {
  top: 42rpx;
  right: 30rpx;
  animation-delay: 0.4s;
}

.bubble-2 {
  top: 218rpx;
  left: 18rpx;
  animation-delay: 0.2s;
}

.bubble-3 {
  top: 214rpx;
  right: 22rpx;
  animation-delay: 0.5s;
}

.health-card {
  position: relative;
  z-index: 1;
  margin-top: -58rpx;
  padding: 34rpx;
}

.health-grid {
  display: grid;
  grid-template-columns: 230rpx 1fr;
  gap: 18rpx;
  align-items: center;
  margin: 24rpx 0 34rpx;
}

.score-panel {
  padding: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 245, 220, 0.7));
}

.score {
  color: #25837f;
  font-size: 92rpx;
  font-weight: 800;
}

.score-total {
  font-size: 28rpx;
}

.metric-row {
  display: flex;
  justify-content: space-between;
  min-height: 52rpx;
  color: #725a64;
  font-size: 24rpx;
}
