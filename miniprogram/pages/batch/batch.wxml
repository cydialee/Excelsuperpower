<view class="page-shell batch-page">
  <view class="nav-row">
    <view class="back-link" bindtap="goBack">‹</view>
    <view class="page-title">批量任务舱</view>
    <view class="star-dot"></view>
  </view>

  <view class="ship-stage">
    <view class="ship-star"></view>
    <view class="ship-window"></view>
    <view class="ship-body"></view>
    <view class="ship-paper left">X</view>
    <view class="ship-paper right">X</view>
  </view>

  <view class="batch-count">{{files.length}} 个文件等待处理</view>
  <view class="soft-panel queue-panel">
    <view wx:for="{{files}}" wx:key="id" class="queue-row">
      <view class="excel-pill">X</view>
      <view class="queue-name">{{item.name}}</view>
      <view class="queue-state">{{item.status}}</view>
    </view>
  </view>
  <button class="primary-button batch-button" bindtap="startBatch">开始批量打印（{{files.length}}）</button>
</view>
