.page-title {
  font-size: 31rpx;
  font-weight: 700;
}

.ship-stage {
  position: relative;
  height: 448rpx;
}

.ship-star {
  position: absolute;
  top: 56rpx;
  left: 320rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  background: #f7c85e;
  transform: rotate(45deg);
}

.ship-body {
  position: absolute;
  right: 118rpx;
  bottom: 72rpx;
  left: 118rpx;
  height: 230rpx;
  border: 4rpx solid #ce665d;
  border-radius: 50% 50% 42% 42%;
  background: linear-gradient(180deg, #ff8e9c, #ef5b6d);
}

.ship-window {
  position: absolute;
  z-index: 1;
  top: 140rpx;
  left: 178rpx;
  width: 342rpx;
  height: 122rpx;
  border: 8rpx solid #ffc77a;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 22% 52%, #ffd7c7 0 34rpx, transparent 36rpx),
    radial-gradient(circle at 50% 52%, #ffd7c7 0 34rpx, transparent 36rpx),
    radial-gradient(circle at 78% 52%, #ffd7c7 0 34rpx, transparent 36rpx),
    #86cad6;
}

.ship-paper {
  position: absolute;
  top: 150rpx;
  display: grid;
  place-items: center;
  width: 82rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: #fffdfa;
  color: #62b98c;
  font-weight: 800;
}

.ship-paper.left {
  left: 38rpx;
  transform: rotate(-18deg);
}

.ship-paper.right {
  right: 34rpx;
  transform: rotate(15deg);
}

.batch-count {
  margin-bottom: 22rpx;
  color: #473039;
  font-size: 31rpx;
  font-weight: 700;
  text-align: center;
}

.quick-panel,
.queue-panel {
  padding: 24rpx;
}

.quick-panel {
  margin-bottom: 18rpx;
}

.quick-plan-row,
.queue-plan-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.quick-plan,
.queue-plan {
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff8ef;
  color: #7a6857;
  font-size: 22rpx;
  line-height: 52rpx;
}

.quick-plan.active,
.queue-plan.active {
  background: #42b8b4;
  color: #fff;
}

.queue-card {
  padding: 18rpx 0 24rpx;
  border-bottom: 2rpx solid #f5e8e6;
}

.queue-card:last-child {
  border-bottom: 0;
}

.queue-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.queue-main {
  flex: 1;
  min-width: 0;
}

.queue-name {
  color: #25443d;
  font-size: 24rpx;
  font-weight: 700;
}

.queue-sub {
  margin-top: 8rpx;
  color: #7b8b80;
  font-size: 20rpx;
}

.queue-input {
  min-height: 68rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border: 2rpx solid #dbc698;
  border-radius: 18rpx;
  background: #fffdf7;
  color: #25443d;
  font-size: 24rpx;
}

.queue-state {
  margin-top: 12rpx;
  color: #3ca16d;
  font-size: 22rpx;
  font-weight: 700;
}

.batch-button {
  margin-top: 24rpx;
}
